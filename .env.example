# Copy this to .env.local and fill in your values

# Private album password (bcrypt hash of the password)
# Generate with: node -e "const bcrypt = require('bcryptjs'); console.log(bcrypt.hashSync('your-password', 10))"
ALBUM_PASSWORD_HASH=

# Optional: upload storage (use Vercel Blob for production)
BLOB_READ_WRITE_TOKEN=

# Optional: ambient audio file URL
NEXT_PUBLIC_AMBIENT_AUDIO_URL=

# Site URL (for SEO)
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# Photographer name (shown in SEO/meta)
NEXT_PUBLIC_PHOTOGRAPHER_NAME=AZ
